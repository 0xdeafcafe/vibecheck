# Caddy reverse proxy for the VPS deploy option.
# Caddy obtains and renews TLS for vibecheck.forbes.red automatically
# (ports 80 + 443 must be reachable; DNS A/AAAA must point at this host).
vibecheck.forbes.red {
	# vibecheck is the compose service name; it listens on :8080
	reverse_proxy vibecheck:8080
}
